# ──────────────────────────────────────────────────────────────
# Business Club Platform — environment variables
# Copy this file to ".env" and fill in the values you need.
# Only DATABASE_URL and SESSION_SECRET are required to boot.
# ──────────────────────────────────────────────────────────────

# ── Core (required) ──
# PostgreSQL connection string (e.g. Neon, Supabase, or self-hosted Postgres)
DATABASE_URL=postgres://user:password@host:5432/dbname
# Secret used to sign session cookies — set to a long random string
SESSION_SECRET=change-me-to-a-long-random-string
# "development" or "production"
NODE_ENV=development
# Port the server listens on
PORT=5000

# ── App URLs (used in outgoing emails) ──
# Full base URL of the deployed app, e.g. https://app.example.com
APP_BASE_URL=
# Bare domain fallback, e.g. app.example.com
APP_DOMAINS=

# ── Email (Resend) ──
RESEND_API_KEY=

# ── Object storage (Google Cloud Storage via a credential sidecar) ──
# NOTE: file upload/download require a sidecar at this endpoint exposing
# /token, /credential and /object-storage/signed-object-url. Run a compatible
# sidecar or adapt server/objectStorage.ts to your provider's native SDK.
STORAGE_SIDECAR_ENDPOINT=http://127.0.0.1:1106
# Audience claim for the external-account token exchange
STORAGE_AUDIENCE=storage
# Comma-separated public search paths and the private object dir
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=
DEFAULT_OBJECT_STORAGE_BUCKET_ID=

# ── Encryption ──
# Key used to encrypt stored integration credentials (falls back to SESSION_SECRET).
# When migrating an existing database, set this to the exact secret used before,
# or previously encrypted rows will fail to decrypt.
INTEGRATION_ENCRYPTION_KEY=

# ── AI (OpenAI-compatible gateway) ──
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
# Direct OpenAI key fallback (used by OCR / startup chat if gateway is unset)
OPENAI_API_KEY=

# ── Cron ──
# Shared secret required by POST /api/cron/:jobName (x-cron-secret header)
CRON_SHARED_SECRET=

# ── Telegram workspace bot (optional) ──
TELEGRAM_BOT_TOKEN=

# ── Inbound email webhooks (optional) ──
INBOUND_EMAIL_DOMAIN=in.example.com
INBOUND_EMAIL_SHARED_SECRET=
RESEND_INBOUND_SECRET=
SENDGRID_INBOUND_PUBLIC_KEY=

# ── OAuth connectors for founder integrations (all optional) ──
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
STRIPE_OAUTH_CLIENT_ID=
STRIPE_SECRET_KEY=
TINKOFF_BUSINESS_OAUTH_CLIENT_ID=
TINKOFF_BUSINESS_OAUTH_CLIENT_SECRET=

# ── Signal source API tokens (all optional) ──
GITHUB_TOKEN=
GITLAB_TOKEN=
HH_RU_TOKEN=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
GIGACHAT_API_KEY=

# ── Telegram MTProto watcher (optional, Wave-2 stub) ──
TG_MTPROTO_API_ID=
TG_MTPROTO_API_HASH=
